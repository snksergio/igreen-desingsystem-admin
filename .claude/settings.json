{
  "permissions": {
    "allow": [
      "mcp__igreen-workspace__read_text_file",
      "mcp__igreen-workspace__list_directory",
      "mcp__igreen-workspace__write_file",
      "Bash(npm run:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(node .claude/scripts/sync-agents-to-cursor.cjs)",
      "Bash(curl -s http://localhost:3100)",
      "Bash(kill %1)",
      "Bash(./node_modules/.bin/tsc --noEmit)",
      "Bash(node node_modules/typescript/bin/tsc --noEmit)",
      "mcp__claude_ai_Figma__get_variable_defs",
      "mcp__figma-console__figma_get_variables",
      "mcp__figma-console__figma_get_status",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_screenshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_screenshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_pages",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__navigate_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__click",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_snapshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__evaluate_script",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__resize_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_console_messages",
      "WebSearch",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:www.tailwind-variants.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:alignui.com)",
      "WebFetch(domain:dev.to)",
      "Read(//d/Projetos/igreen-workspace/**)",
      "Read(//d/Projetos/igreen-workspace/.claude/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/format-on-save.sh" },
          { "type": "command", "command": ".claude/hooks/ds-lint-styles.sh" },
          { "type": "command", "command": ".claude/hooks/ds-inventory-check.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-rm-rf.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-sensitive-edit.sh" }
        ]
      }
    ]
  },
  "outputStyle": "terse"
}
